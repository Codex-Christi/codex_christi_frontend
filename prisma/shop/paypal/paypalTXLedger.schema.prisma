datasource db {
  provider = "postgresql"
  // URL is set in prisma.config.ts (Prisma 7 style)
}

generator paypalTxLedger {
  provider = "prisma-client"
  output   = "../../../src/lib/prisma/shop/paypal/txLedger/generated/paypalTxLedger"
}

model PaypalIntent {
  id                                 String    @id @default(cuid())
  orderToken                         String    @unique
  paypalOrderId                      String?   @unique
  paypalAuthorizationId              String?
  djangoOrderIntentUuid              String?
  djangoOrderIntentOrderId           String?
  customerName                       String
  customerEmail                      String
  userId                             String?
  countryIso2                        String?
  countryIso3                        String?
  initialCurrency                    String?
  cartSnapshot                       Json
  shippingSnapshot                   Json
  // Raw payloads needed to reuse your existing server actions
  authorizePayload                   Json?
  capturePayload                     Json?
  djangoOrderIntentPayload           Json?
  djangoOrderIntentVerifyPayload     Json?
  djangoPaymentSaveResponsePayload   Json?
  merchizeFulfillmentRequestPayload  Json?
  merchizeFulfillmentResponsePayload Json?
  merchizeFulfillmentProcessingId    String?
  merchizeProviderOrderId            String?
  merchizeProviderOrderCode          String?
  fulfillmentAddressOverride         Json?
  fulfillmentAddressOverrideReason   String?
  fulfillmentAddressOverriddenBy     String?
  fulfillmentAddressOverriddenAt     DateTime?
  djangoPaymentSaveCustomId          String?
  receiptLink                        String?
  receiptFile                        String?
  status                             String
  lastEventType                      String?
  lastErrorCode                      String?
  lastErrorMessage                   String?
  retryCount                         Int       @default(0)
  processingTriggerSource            String?
  processingTriggerDetail            String?
  processingTriggeredAt              DateTime?
  postProcessingLockId               String?
  postProcessingLockedAt             DateTime?
  postProcessingLockExpiresAt        DateTime?
  processingCompletedAt              DateTime?
  createdAt                          DateTime  @default(now())
  updatedAt                          DateTime  @updatedAt

  @@index([customerEmail])
  @@index([djangoOrderIntentUuid])
  @@index([djangoOrderIntentOrderId])
  @@index([djangoPaymentSaveCustomId])
  @@index([status])
  @@index([createdAt])
  @@index([processingTriggerSource])
  @@index([postProcessingLockExpiresAt])
}

model PaypalWebhookEvent {
  id                       String    @id @default(cuid())
  eventId                  String    @unique
  eventType                String
  orderToken               String?
  paypalOrderId            String?
  payload                  Json
  matchedWebhookId         String?
  matchedWebhookSource     String?
  matchedWebhookBindingKey String?
  matchedWebhookLabel      String?
  webhookVerificationMode  String?
  processingStatus         String    @default("received")
  attemptCount             Int       @default(0)
  lastAttemptAt            DateTime?
  processedAt              DateTime?
  lastErrorMessage         String?
  createdAt                DateTime  @default(now())

  @@index([orderToken])
  @@index([paypalOrderId])
  @@index([eventType])
  @@index([matchedWebhookSource])
  @@index([matchedWebhookBindingKey])
  @@index([processingStatus])
  @@index([processedAt])
  @@index([createdAt])
}

model PaypalLedgerTransactionWebhookBinding {
  id                        String    @id @default(cuid())
  key                       String    @unique
  paypalPaymentMode         String
  deploymentTarget          String
  envVarName                String
  label                     String
  webhookId                 String
  webhookUrl                String?
  expectedUrl               String?
  eventTypes                String[]  @default([])
  isActive                  Boolean   @default(false)
  lastSyncStatus            String    @default("unknown")
  lastSyncSummary           String?
  lastObservedEnvWebhookId  String?
  lastCheckedAt             DateTime?
  lastNotifiedAt            DateTime?
  lastNotificationDedupeKey String?
  createdByAdminId          String?
  createdByCodexUserId      String?
  updatedByAdminId          String?
  updatedByCodexUserId      String?
  activatedByAdminId        String?
  activatedByCodexUserId    String?
  activatedAt               DateTime?
  deactivatedAt             DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@index([paypalPaymentMode, isActive])
  @@index([deploymentTarget])
  @@index([envVarName])
  @@index([lastSyncStatus])
  @@index([updatedAt])
}

model PaidOrderRecoveryProjection {
  id         String @id @default(cuid())
  orderToken String @unique

  paypalOrderId             String?
  djangoOrderIntentUuid     String?
  djangoOrderIntentOrderId  String?
  djangoPaymentSaveCustomId String?
  userId                    String?
  customerEmail             String
  customerName              String

  paypalLedgerStatus          String
  adminRecoveryStatus         String
  customerRecoveryStatus      String
  isPaid                      Boolean @default(false)
  isQueueVisible              Boolean @default(false)
  isCustomerProtectionVisible Boolean @default(false)
  isResolved                  Boolean @default(false)

  needsProviderDetailSync    Boolean @default(false)
  needsAdminAttention        Boolean @default(false)
  canRetryFullPostProcessing Boolean @default(false)
  canRetryFulfillment        Boolean @default(false)
  canSyncProviderDetails     Boolean @default(false)

  merchizeExternalOrderNumber  String?
  merchizeOrderId              String?
  merchizeOrderCode            String?
  merchizeOpsSyncStatus        String?
  merchizeProductionGateStatus String?
  merchizeProgressStatus       String?
  merchizeDeliveryStatus       String?

  receiptLink                   String?
  receiptFile                   String?
  paidAmountLabel               String?
  processingSourceLabel         String?
  processingSourceTone          String?
  latestWebhookSourceLabel      String?
  latestWebhookEventType        String?
  latestWebhookProcessingStatus String?
  lastErrorCode                 String?
  lastErrorMessage              String?
  recoveryReason                String?
  recoveryStage                 String?
  recoverySeverity              String?

  paypalIntentUpdatedAt DateTime?
  merchizeOpsUpdatedAt  DateTime?
  projectedAt           DateTime  @default(now())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([adminRecoveryStatus, updatedAt])
  @@index([customerRecoveryStatus, updatedAt])
  @@index([isQueueVisible, updatedAt])
  @@index([isCustomerProtectionVisible, updatedAt])
  @@index([customerEmail, updatedAt])
  @@index([paypalLedgerStatus])
  @@index([djangoPaymentSaveCustomId])
  @@index([needsProviderDetailSync])
  @@index([needsAdminAttention])
}

model CheckoutRecoveryOtpChallenge {
  id           String    @id @default(cuid())
  email        String
  otpHash      String
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int       @default(0)
  createdAt    DateTime  @default(now())

  @@index([email, expiresAt])
  @@index([consumedAt])
}

model AdminNotificationOutbox {
  id               String    @id @default(cuid())
  orderToken       String?
  paypalOrderId    String?
  type             String
  stage            String?
  errorCode        String?
  severity         String    @default("warning")
  status           String    @default("pending")
  dedupeKey        String    @unique
  recipient        String?
  payload          Json
  attemptCount     Int       @default(0)
  lastAttemptAt    DateTime?
  sentAt           DateTime?
  lastErrorMessage String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([orderToken])
  @@index([paypalOrderId])
  @@index([type])
  @@index([stage])
  @@index([errorCode])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

model CustomerNotificationOutbox {
  id               String    @id @default(cuid())
  orderToken       String
  paypalOrderId    String?
  type             String
  status           String    @default("pending")
  dedupeKey        String    @unique
  recipient        String
  payload          Json
  attemptCount     Int       @default(0)
  lastAttemptAt    DateTime?
  sentAt           DateTime?
  lastErrorMessage String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([orderToken])
  @@index([paypalOrderId])
  @@index([type])
  @@index([status])
  @@index([recipient])
  @@index([createdAt])
}
